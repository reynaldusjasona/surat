generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  role      String   @default("host")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  events                  Event[]
  organizerTeams          TeamMember[]
  photographerAssignments PhotographerAssignment[]

  @@map("profiles")
}

model Event {
  id             String    @id @default(uuid()) @db.Uuid
  hostId         String    @map("host_id") @db.Uuid
  slug           String    @unique
  title          String
  type           String    @default("wedding")
  date           DateTime
  time           String?
  location       String?
  mapsUrl        String?   @map("maps_url")
  description    String?
  coverImage     String?   @map("cover_image")
  plan           String    @default("free")
  guestLimit     Int       @default(50) @map("guest_limit")
  photoLimit     Int       @default(50) @map("photo_limit")
  enableRsvp     Boolean   @default(true) @map("enable_rsvp")
  enableAngpao   Boolean   @default(true) @map("enable_angpao")
  enableRegistry Boolean   @default(true) @map("enable_registry")
  enablePhotos   Boolean   @default(true) @map("enable_photos")
  status         String    @default("active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  host                    Profile                  @relation(fields: [hostId], references: [id])
  rsvps                   Rsvp[]
  angpaos                 Angpao[]
  registryItems           RegistryItem[]
  photos                  Photo[]
  photographerAssignments PhotographerAssignment[]

  @@index([hostId])
  @@index([slug])
  @@map("events")
}

model Rsvp {
  id           String   @id @default(uuid()) @db.Uuid
  eventId      String   @map("event_id") @db.Uuid
  name         String
  email        String
  status       String   @default("attending")
  plusOnes     Json?    @map("plus_ones")
  dietaryNotes String?  @map("dietary_notes")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
  @@index([eventId])
  @@map("rsvps")
}

model Angpao {
  id          String  @id @default(uuid()) @db.Uuid
  eventId     String  @map("event_id") @db.Uuid
  senderName  String  @map("sender_name")
  senderEmail String  @map("sender_email")
  amount      Decimal @db.Decimal(12, 2)
  currency    String  @default("SGD")
  message     String?
  isAnonymous Boolean @default(false) @map("is_anonymous")
  isThanked   Boolean @default(false) @map("is_thanked")
  commission  Decimal @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("angpaos")
}

model RegistryItem {
  id               String   @id @default(uuid()) @db.Uuid
  eventId          String   @map("event_id") @db.Uuid
  name             String
  brand            String?
  price            Decimal  @db.Decimal(12, 2)
  productUrl       String?  @map("product_url")
  imageUrl         String?  @map("image_url")
  priority         Int      @default(5)
  status           String   @default("available")
  claimedBy        String?  @map("claimed_by")
  claimedByEmail   String?  @map("claimed_by_email")
  claimedAnonymous Boolean  @default(false) @map("claimed_anonymous")
  createdAt        DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("registry_items")
}

model Photo {
  id             String   @id @default(uuid()) @db.Uuid
  eventId        String   @map("event_id") @db.Uuid
  uploaderName   String   @map("uploader_name")
  uploaderEmail  String   @map("uploader_email")
  isPhotographer Boolean  @default(false) @map("is_photographer")
  originalUrl    String   @map("original_url")
  thumbnailUrl   String   @map("thumbnail_url")
  fileSize       Int      @default(0) @map("file_size")
  downloadCount  Int      @default(0) @map("download_count")
  createdAt      DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("photos")
}

model PhotoUnlock {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  email     String
  amount    Decimal  @db.Decimal(12, 2)
  currency  String   @default("SGD")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@map("photo_unlocks")
}

model PhotographerAssignment {
  id             String   @id @default(uuid()) @db.Uuid
  eventId        String   @map("event_id") @db.Uuid
  photographerId String   @map("photographer_id") @db.Uuid
  revenueShare   Int      @default(60) @map("revenue_share")
  createdAt      DateTime @default(now()) @map("created_at")

  event        Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photographer Profile @relation(fields: [photographerId], references: [id])

  @@unique([eventId, photographerId])
  @@map("photographer_assignments")
}

model TeamMember {
  id          String   @id @default(uuid()) @db.Uuid
  organizerId String   @map("organizer_id") @db.Uuid
  memberId    String?  @map("member_id") @db.Uuid
  email       String
  role        String   @default("member")
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")

  organizer Profile @relation(fields: [organizerId], references: [id])

  @@map("team_members")
}

model Transaction {
  id          String   @id @default(uuid()) @db.Uuid
  type        String
  referenceId String   @map("reference_id") @db.Uuid
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("SGD")
  status      String   @default("completed")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("transactions")
}
